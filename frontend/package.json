{
  "name": "cafe-smart-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --strictPort",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "android:run": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android.ps1",
    "android:fast": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android.ps1",
    "android:launch": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android.ps1 -LaunchOnly",
    "android:full": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-android.ps1 -ForceWebBuild -ForceGradleBuild",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@react-oauth/google": "^0.13.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.14",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "vite": "^5.4.11",
    "vitest": "^1.6.0"
  }
}
