# Si usas un dispositivo fisico en la misma red, usa la IP local de tu PC:
# VITE_API_URL="http://192.168.1.100:3000"

VITE_GOOGLE_CLIENT_ID="TU_CLIENT_ID_DE_GOOGLE.apps.googleusercontent.com"
