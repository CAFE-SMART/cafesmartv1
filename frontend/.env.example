# ============================================================
# frontend/.env.example
# Plantilla para frontend web y Android
# ============================================================

# Backend para desarrollo web local
VITE_API_URL=http://localhost:3000

# Backend para Android o produccion apuntando a Render.
# No pegues credenciales reales aqui; usa este formato en tu .env, .env.production o .env.android.
# VITE_API_URL=https://TU_BACKEND_RENDER.onrender.com

# Android emulator:
# VITE_API_URL=http://10.0.2.2:3000

# Android en dispositivo fisico:
# VITE_API_URL=http://IP_DEL_PC:3000

# Nota:
# - pnpm build usa el modo normal de Vite y no carga .env.android automaticamente.
# - pnpm build:android usa vite build --mode android y si carga frontend/.env.android.
# - Si VITE_API_URL no existe o apunta a localhost, Android usa http://10.0.2.2:3000
#   salvo que VITE_KEEP_ANDROID_LOCALHOST=true.

# Google OAuth Client ID usado por la app web.
# Autoriza estos origins en Google Cloud Console:
# - http://localhost:5173
# - http://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Para Android nativo, configura en Google Cloud Console:
# - package name: com.cafesmart.app
# - SHA-1 del keystore/debug keystore del equipo
