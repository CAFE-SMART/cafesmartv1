# ============================================================
# frontend/.env.example
# Plantilla para frontend web y Android
# ============================================================

# Backend para desarrollo web local
VITE_API_URL=http://localhost:3000

# Backend para Android apuntando al Render propio de pruebas.
# Copia esta linea en frontend/.env.android para compilar Android con tu backend.
# VITE_API_URL=https://cafesmart-v1.onrender.com

# Android emulator con backend local del PC:
# VITE_API_URL=http://10.0.2.2:3000

# Android en dispositivo fisico con backend local del PC:
# VITE_API_URL=http://IP_DEL_PC:3000

# Nota:
# - pnpm build usa el modo normal de Vite y no carga .env.android automaticamente.
# - Para APK/AAB instalado, define VITE_API_URL con un backend https real
#   en .env.production o compila con pnpm build:android.
# - pnpm build:android usa vite build --mode android y si carga frontend/.env.android.
# - En desarrollo Android, si VITE_API_URL no existe o apunta a localhost,
#   Android usa http://10.0.2.2:3000 salvo que VITE_KEEP_ANDROID_LOCALHOST=true.

# Google OAuth Client ID usado por la app web.
# Autoriza estos origins en Google Cloud Console:
# - http://localhost:5173
# - http://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Para Android nativo, configura en Google Cloud Console:
# - package name: com.cafesmart.app
# - SHA-1 del keystore/debug keystore del equipo
