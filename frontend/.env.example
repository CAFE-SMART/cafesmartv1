# ============================================================\n
# frontend/.env.example\n
# Template for all environments\n
# ============================================================\n\n
# Backend URL\nVITE_API_URL=http://localhost:3000\n
# Android emulator: http://10.0.2.2:3000\n
# Physical device: http://192.168.X.X:3000\n\
# Google OAuth Client IDs (separados por plataforma)\n
# Web Client ID - authorize origins in Google Cloud Console:\n
#   http://localhost:5173\n
# http://127.0.0.1:5173\n
# VITE_GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com\n\n
# Android Client ID - configure in Google Cloud Console for Android:\n
#   SHA-1, package name, redirect URI\n