# Base de datos
# Prisma en este proyecto requiere SIEMPRE DATABASE_URL y DIRECT_URL.
#
# Para un backend NestJS persistente como este, si todavia trabajas sin IPv4 dedicada,
# usa el pooler de Supabase en session mode (puerto 5432) para DATABASE_URL.
DATABASE_URL="postgresql://postgres.PROYECTO:CLAVE@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# DIRECT_URL se usa para comandos de Prisma como migrate o db pull.
# Si tu entorno ya soporta IPv6 o luego compras IPv4 dedicada, cambia esta URL por la conexion directa:
# postgresql://postgres:CLAVE@db.PROYECTO.supabase.co:5432/postgres?sslmode=require
#
# Mientras sigas limitado a IPv4, puedes dejar temporalmente la misma URL de session mode para no bloquear Prisma CLI.
DIRECT_URL="postgresql://postgres.PROYECTO:CLAVE@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Backend
PORT=3000
JWT_SECRET="cambia-esto-por-un-secreto-largo"
AUTH_RATE_LIMIT_MAX_REQUESTS=15
AUTH_RATE_LIMIT_WINDOW_MS=60000
PRISMA_CONNECT_MAX_ATTEMPTS=5
PRISMA_CONNECT_RETRY_DELAY_MS=3000

# Google OAuth
# Opcion 1: un solo client id (solo web)
GOOGLE_CLIENT_ID="TU_CLIENT_ID_WEB.apps.googleusercontent.com"

# Opcion 2: varios client id (web + android)
# Si defines GOOGLE_CLIENT_IDS, el backend validara contra todos.
GOOGLE_CLIENT_IDS="TU_CLIENT_ID_WEB.apps.googleusercontent.com,TU_CLIENT_ID_ANDROID.apps.googleusercontent.com"
