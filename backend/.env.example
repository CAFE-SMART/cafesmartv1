# Base de datos
# Opcion recomendada para Supabase usando el pooler (funciona mejor mientras trabajas sin IPv4 dedicada)
DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Opcion directa para migraciones/introspeccion.
# Si tu red todavia no resuelve IPv6, puedes dejarla igual a DATABASE_URL temporalmente.
DIRECT_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Alternativa: si no quieres guardar la URL completa, el backend tambien puede construirla con estas variables.
SUPABASE_DB_HOST="aws-0-TU_REGION.pooler.supabase.com"
SUPABASE_DB_PORT="6543"
SUPABASE_DB_USER="postgres.TU_PROJECT_REF"
SUPABASE_DB_PASSWORD="TU_PASSWORD"
SUPABASE_DB_NAME="postgres"

# Backend
PORT=3000
JWT_SECRET="cambia-esto-por-un-secreto-largo"

# Google OAuth
# Opcion 1: un solo client id (solo web)
GOOGLE_CLIENT_ID="TU_CLIENT_ID_WEB.apps.googleusercontent.com"

# Opcion 2: varios client id (web + android)
# Si defines GOOGLE_CLIENT_IDS, el backend validara contra todos.
GOOGLE_CLIENT_IDS="TU_CLIENT_ID_WEB.apps.googleusercontent.com,TU_CLIENT_ID_ANDROID.apps.googleusercontent.com"
