# Base de datos Supabase
# Conexion usada por el backend en ejecucion normal.
# Solo reemplaza TU_PASSWORD.
DATABASE_URL="postgresql://postgres.ielltlinimqcnwlkvrbs:TU_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require&channel_binding=disable"
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://192.168.100.7:5173,http://192.168.100.7:4173
EMAIL_FROM="Cafe Smart <soporte@cafesmart.com>"
# Configure one provider to enable password recovery emails:
# RESEND_API_KEY=
# SENDGRID_API_KEY=

# Conexion directa usada por Prisma para db pull, db push y tareas de esquema.
# Solo reemplaza TU_PASSWORD.
DIRECT_URL="postgresql://postgres:TU_PASSWORD@db.ielltlinimqcnwlkvrbs.supabase.co:5432/postgres?sslmode=require&channel_binding=disable"

# Backend
PORT=3000
JWT_SECRET="cambia-esto-por-un-secreto-largo"
# AI_PROVIDER soporta: gemini, openai, mock, none
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=gemini-2.5-flash

# Google OAuth
# Opcion 1: un solo client id (solo web)
GOOGLE_CLIENT_ID="TU_CLIENT_ID_WEB.apps.googleusercontent.com"

# Opcion 2: varios client id (web + android)
# Si defines GOOGLE_CLIENT_IDS, el backend validara contra todos.
GOOGLE_CLIENT_IDS="TU_CLIENT_ID_WEB.apps.googleusercontent.com,TU_CLIENT_ID_ANDROID.apps.googleusercontent.com"

# Prisma
PRISMA_CONNECT_MAX_ATTEMPTS=5
PRISMA_CONNECT_RETRY_DELAY_MS=3000
